# TikTok Session ID (optional)
SESSIONID=your_tiktok_session_id_here

# YouTube API Key (required for YouTube connections)
# Get your API key from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Twitch API Selection
# Set to 'true' to use official Twitch Helix API (enables followers)
# Set to 'false' or leave empty to use tmi.js (chat, subs, gifts, raids)
TWITCH_USE_OFFICIAL_API=false

# Twitch OAuth Token (optional, for tmi.js authenticated connections)
# Get your OAuth token from: https://twitchapps.com/tmi/
# Leave empty or unset for anonymous mode (read-only chat, works for any channel)
TWITCH_OAUTH_TOKEN=

# Twitch Username (optional, defaults to justinfan12345 for anonymous)
TWITCH_USERNAME=your_twitch_username

# Twitch Access Token (optional, required for fetching follower details with user info)
# Get your access token from: https://twitchtokengenerator.com/
# Scope needed: 'moderator:read:followers' for own channel, or 'user:read:follows'
# Without this, only follower count is available (no individual follower details)
TWITCH_ACCESS_TOKEN=

# Twitch Client ID and Secret (required for official Twitch Helix API)
# Get your Twitch Developer credentials from: https://dev.twitch.tv/console
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here

# Server Port (optional, defaults to 8081)
PORT=8081

# Enable Rate Limiting (optional)
ENABLE_RATE_LIMIT=true
