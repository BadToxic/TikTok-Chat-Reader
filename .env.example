# TikTok Session ID (optional)
SESSIONID=your_tiktok_session_id_here

# YouTube API Key (required for YouTube connections)
# Get your API key from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Twitch OAuth Token (optional, for authenticated Twitch connections)
# Get your OAuth token from: https://twitchapps.com/tmi/
TWITCH_OAUTH_TOKEN=oauth:your_oauth_token_here

# Twitch Username (optional, defaults to justinfan12345 for anonymous)
TWITCH_USERNAME=your_twitch_username

# Server Port (optional, defaults to 8081)
PORT=8081

# Enable Rate Limiting (optional)
ENABLE_RATE_LIMIT=true
